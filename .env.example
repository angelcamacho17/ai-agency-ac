# Copy this to .env and fill in. Never commit .env.
# Get a fresh key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to the cheapest model.
ANTHROPIC_MODEL=claude-haiku-4-5
PORT=8080

# Optional. Comma-separated list of allowed frontend origins if you split deploy.
# Leave empty for same-origin only (default).
# Example: FRONTEND_ORIGINS=https://michelangelodevs.com,https://www.michelangelodevs.com
FRONTEND_ORIGINS=

# IMPORTANT: also set a monthly spend cap in the Anthropic console:
#   https://console.anthropic.com/settings/billing
# The in-memory rate limiter resets on every server restart — the console cap
# is the only true backstop against runaway spend.
